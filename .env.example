# Autonomous Sales Agent — environment template.
# Copy to .env (gitignored) and fill in real values. NEVER commit .env.
# Plan: docs/plans/2026-05-31-001-feat-voice-sales-agent-plan.md

# --- LLM access: OpenRouter (one key -> many models, OpenAI-compatible) ---
OPENROUTER_API_KEY=
# Model selection (pick TOOL-CAPABLE models; agent vs sim/judge should be DIFFERENT families)
AGENT_MODEL=anthropic/claude-sonnet-4.5
SIM_MODEL=openai/gpt-4o
JUDGE_MODEL=openai/gpt-4o
# Optional direct-provider keys (only if NOT routing via OpenRouter)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# --- KB embeddings: local open model, no key (sentence-transformers) ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Speech-to-text: handled by ElevenLabs Scribe v2 Realtime (uses ELEVENLABS_API_KEY below).
#     Deepgram is an OPTIONAL drop-in fallback only if live turn-taking lags. ---
# DEEPGRAM_API_KEY=

# --- Text-to-speech ---
ELEVENLABS_API_KEY=
# CARTESIA_API_KEY=        # optional low-latency alternative

# --- Voice infrastructure (LiveKit, self-hosted or cloud) ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Database (default points at the docker-compose Postgres+pgvector) ---
DATABASE_URL=postgresql://sales:sales@localhost:5434/sales_agent

# --- Observability (optional) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- App ---
APP_ENV=dev
