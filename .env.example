# Autonomous Sales Agent — environment template.
# Copy to .env (gitignored) and fill in real values. NEVER commit .env.
# Plan: docs/plans/2026-05-31-001-feat-voice-sales-agent-plan.md

# --- Agent brain LLM (Claude) ---
ANTHROPIC_API_KEY=

# --- Prospect simulator + judges (a DIFFERENT family than the agent; pick one) ---
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Speech-to-text ---
DEEPGRAM_API_KEY=

# --- Text-to-speech ---
ELEVENLABS_API_KEY=
# CARTESIA_API_KEY=        # optional low-latency alternative

# --- Voice infrastructure (LiveKit, self-hosted or cloud) ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Database (default points at the docker-compose Postgres+pgvector) ---
DATABASE_URL=postgresql://sales:sales@localhost:5432/sales_agent

# --- Observability (optional) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- App ---
APP_ENV=dev
